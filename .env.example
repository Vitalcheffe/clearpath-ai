# ═══════════════════════════════════════════════════════
# ClearPath AI — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════

# ─── DATABASE ─────────────────────────────────────────
# Local development: SQLite
DATABASE_URL="file:../db/custom.db"

# Vercel deployment: Use Turso (libSQL) for persistent SQLite
# 1. Install Turso CLI: curl -sSfL https://get.turso.dev | bash
# 2. Create database: turso db create clearpath-ai
# 3. Get URL: turso db show clearpath-ai --url
# 4. Get auth token: turso db tokens create clearpath-ai
# DATABASE_URL="libsql://clearpath-ai-xxxx.aws-eu-west-1.turso.io?authToken=xxxx"

# ─── AI: HUGGING FACE ────────────────────────────────
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a token with "Read" access
# Without this key, the classify API falls back to keyword-based matching
HUGGINGFACE_API_KEY="hf_xxxxx"
