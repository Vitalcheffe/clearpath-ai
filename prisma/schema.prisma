// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core Models (used by the app) ────────────────────────

model Resource {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String
  phone       String?
  address     String?
  hours       String?
  eligibility String?
  services    String?  // comma-separated
  languages   String?  // comma-separated
  lastVerified String?
  url         String?
  createdAt   DateTime @default(now())
}

// ─── Preserved Models (used by seed & future features) ────

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  image         String?
  username      String?  @unique
  location      String?
  language      String   @default("en")
  plan          String   @default("free")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversations Conversation[]
  savedResources SavedResource[]
  userSettings   UserSettings?
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  preview     String
  category    String?
  categoryColor String?
  confidence  Int      @default(0)
  isCrisis    Boolean  @default(false)
  isGuest     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("Conversation")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "ai" | "system"
  text           String
  category       String?
  confidence     Int?
  isCrisis       Boolean  @default(false)
  alternatives   String?  // JSON string
  resources      String?  // JSON string
  why            String?
  also           String?
  warning        String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("Message")
}

model SavedResource {
  id             String   @id @default(cuid())
  userId         String
  title          String
  category       String
  categoryColor  String   @default("#3b82f6")
  confidence     Int      @default(0)
  verifiedDate   String?
  action         String?
  detail         String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  language              String  @default("English")
  theme                 String  @default("light")
  zipCode               String?
  confidenceThreshold   Int     @default(70)
  defaultCategory       String  @default("All")
  autoClarification     Boolean @default(true)
  distanceUnit          String  @default("miles")
  fontSize              String  @default("normal")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
